generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PortalRole {
  uploader
  admin

  @@map("portal_role")
}

model AllowedUser {
  id        BigInt     @id @default(autoincrement()) @db.BigInt
  email     String     @unique @db.Text
  role      PortalRole @default(uploader)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  images    Image[]

  @@map("allowed_users")
}

model Image {
  id               String      @id @default(uuid()) @db.Uuid
  title            String?     @db.Text
  caption          String?     @db.Text
  altText          String?     @map("alt_text") @db.Text
  storagePath      String      @unique @map("storage_path") @db.Text
  publicUrl        String      @map("public_url") @db.Text
  uploadedByEmail  String      @map("uploaded_by_email") @db.Text
  uploadedByUserId BigInt      @map("uploaded_by_user_id") @db.BigInt
  uploadedByUser   AllowedUser @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?   @map("deleted_at") @db.Timestamptz(6)
  isVisible        Boolean     @default(true) @map("is_visible")
  displayOrder     Int         @default(0) @map("display_order")

  @@index([deletedAt], map: "images_deleted_at_idx")
  @@index([displayOrder, createdAt], map: "images_display_order_created_at_idx")
  @@index([uploadedByEmail], map: "images_uploaded_by_email_idx")
  @@index([uploadedByUserId, deletedAt], map: "images_uploaded_by_user_id_deleted_at_idx")
  @@index([isVisible, displayOrder], map: "images_is_visible_display_order_idx")
  @@map("images")
}
